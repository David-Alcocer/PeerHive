# =============================================================================
# PeerHive - Archivo de Variables de Entorno (Template)
# =============================================================================
# COPIAR ESTE ARCHIVO A .env Y COMPLETAR LOS VALORES REALES
# NUNCA COMMITEAR .env AL REPOSITORIO

# =============================================================================
# SEGURIDAD - OBLIGATORIOS
# =============================================================================

# Clave secreta para JWT y cifrado de tokens
# Generar con: openssl rand -hex 32
SECRET_KEY=2b65ec72021b9044379e96284fd032471d41135711f43cb38b0a2398244cfda0

# =============================================================================
# MONGODB - AUTENTICACIÓN
# =============================================================================

# Usuario y contraseña de MongoDB (crear en初始化)
MONGO_USERNAME=peerhive_user
MONGO_PASSWORD=change_this_password_in_production

# URL de conexión (se construye con las credenciales arriba)
# MONGO_URL=mongodb://peerhive_user:change_this_password_in_production@mongo:27017

# Nombre de la base de datos
DB_NAME=peerhive

# =============================================================================
# MICROSOFT AZURE AD - OAUTH2
# =============================================================================

# Tenant ID de Azure AD
AZURE_TENANT_ID=your-azure-tenant-id

# Client ID de la aplicación registrada en Azure AD
AZURE_CLIENT_ID=your-azure-client-id

# Client Secret de la aplicación registrada en Azure AD
AZURE_CLIENT_SECRET=your-azure-client-secret

# URI de redirección después del login OAuth
REDIRECT_URI=http://localhost:8000/auth/callback

# =============================================================================
# CONFIGURACIÓN ADICIONAL
# =============================================================================

# Puerto del servidor
PORT=8000

# Entorno (development/production)
ENVIRONMENT=development

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000
